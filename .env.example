# ============================================================
# Database (Supabase PostgreSQL via Prisma)
# Isi dari Supabase Dashboard > Connect.
# DATABASE_URL  = Transaction pooler untuk runtime/serverless (Vercel).
# DIRECT_URL    = Direct/session connection untuk Prisma db push/migration.
# TEST_DATABASE_URL wajib memakai Supabase project khusus test, bukan production.
# ============================================================
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
# ============================================================
# Auth — secret untuk sign JWT session admin
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
AUTH_SECRET="replace-with-random-32-byte-hex-string"

# ============================================================
# Seed admin (development/local only)
# ============================================================
ADMIN_SEED_EMAIL="admin@uny.ac.id"
ADMIN_SEED_PASSWORD="replace-with-admin-password-min-12-chars"
ADMIN_SEED_NAME="Administrator"

# ============================================================
# Pinata IPFS (server-side only)
# ============================================================
PINATA_JWT=your_pinata_jwt
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs
REQUIRE_PINATA_UPLOAD=false

# ============================================================
# Blockchain (Bonus — optional)
# ============================================================
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-key
CONTRACT_ADDRESS=0xYourContractAddress
SERVER_WALLET_PRIVATE_KEY=0xyourprivatekey

# ============================================================
# Public config (boleh diakses frontend)
# ============================================================
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_EXPLORER_BASE_URL=https://sepolia.etherscan.io
