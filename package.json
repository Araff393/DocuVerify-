{
  "name": "certchain-verify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate:sqlite-to-supabase": "dotenv -e .env.local -- node scripts/migrate-sqlite-to-supabase.mjs",
    "db:migrate:document-types": "node scripts/migrate-document-types-to-certificates.mjs",
    "db:backfill-public-codes": "dotenv -e .env.local -- tsx scripts/backfill-public-codes.ts",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:reset": "dotenv -e .env.local -- prisma db push --force-reset && npm run db:seed",
    "test:api": "vitest run",
    "test:api:watch": "vitest",
    "test:typecheck": "tsc --noEmit",
    "test": "npm run test:api",
    "compile:contract": "hardhat compile",
    "test:contract": "hardhat test"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "ethers": "^6.14.3",
    "jose": "^6.2.3",
    "next": "^15.2.4",
    "pinata": "^2.5.6",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.6.1",
    "dotenv-cli": "^11.0.0",
    "hardhat": "^2.24.1",
    "pg": "^8.21.0",
    "postcss": "^8.5.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
